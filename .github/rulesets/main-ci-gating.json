{
  "name": "main-ci-gating",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/main"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          {
            "context": "build"
          },
          {
            "context": "check-fmt"
          },
          {
            "context": "lint"
          },
          {
            "context": "test"
          },
          {
            "context": "docs-gate"
          }
        ]
      }
    }
  ]
}
